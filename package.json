  "type": "module",
  "exports": {
    "./trpc": "./server/trpc/router.ts"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
